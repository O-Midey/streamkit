# Model provider (the demo route uses OpenAI)
OPENAI_API_KEY=your_key_here

# Optional: Anthropic, if you switch the route to the Anthropic adapter
ANTHROPIC_API_KEY=your_key_here

# Rate limiting (Upstash Redis) — protects your API credits on a public deploy.
# Create a free database at https://console.upstash.com and copy the REST creds.
# If these are unset, rate limiting is disabled (fine for local dev, NOT for prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
